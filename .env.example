# Backend (required unless using spring.profiles.active=dev)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
DB_PASSWORD=change-me-to-a-strong-password

# Optional overrides
DB_URL=jdbc:h2:file:./antivirus_db
DB_USERNAME=sa
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000

# Frontend (create frontend/.env.local from these values)
REACT_APP_API_URL=http://localhost:8080
REACT_APP_API_USERNAME=admin
REACT_APP_API_PASSWORD=change-me-to-a-strong-password
