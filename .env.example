# Backend (required unless using spring.profiles.active=dev)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password
DB_PASSWORD=change-me-to-a-strong-password

# Optional overrides
DB_URL=jdbc:h2:file:./antivirus_db
DB_USERNAME=sa
CORS_ALLOWED_ORIGINS=http://localhost:5000,http://localhost:3000,http://localhost:5173

# Frontend (copy frontend/.env.example to frontend/.env.local)
VITE_API_URL=http://localhost:8080
VITE_API_USERNAME=admin
# Use admin123 when backend runs with SPRING_PROFILES_ACTIVE=dev
VITE_API_PASSWORD=admin123
